# ─────────────────────────────────────────────────
# EasyOref — Configuration
# Copy this file to config.yaml and fill in your values.
# ─────────────────────────────────────────────────

# ── Monitoring ────────────────────────────────────
# City IDs to monitor (from cities.json).
# Find IDs: https://raw.githubusercontent.com/eladnava/pikud-haoref-api/master/cities.json
# Example: 722 = תל אביב - דרום העיר ויפו
city_ids:
  - 722
  # - 723  # Another area...

# Which alert types to forward (omit = all three):
#   early      — early warning (e.g. hostiles detected)
#   red_alert  — red alert / rocket siren
#   resolved   — all-clear
alert_types:
  - early
  - red_alert
  - resolved

# ── Telegram ──────────────────────────────────────
telegram:
  bot_token: ""        # from @BotFather (or mount Docker secret)
  chat_id: ""          # string or list: "-100123" or ["-100123", "-100456"]

# ── Language & GIF ────────────────────────────────
# ru | en | he | ar
language: ru

# funny_cats | none
gif_mode: none

# ── Overrides (optional) ─────────────────────────
# Override the default emoji, title, or description per alert type.
# Each field is independent — override any combination.
# Leave commented out to use built-in i18n strings.
#
# emoji_override:
#   early: "🚀"
#   red_alert: "🛑"
#   resolved: "✅"
#
# title_override:
#   red_alert: "Azaka"
#   early: "Early warning"
#   resolved: "All clear"
#
# description_override:
#   red_alert: ""                          # empty string = no description line
#   early: "Stay alert, follow instructions."
#   resolved: "You may leave the shelter."

# ── Observability (optional) ─────────────────────
# observability:
#   betterstack_token: ""   # Logtail source token

# ── Advanced ─────────────────────────────────────
# poll_interval_ms: 2000
# health_port: 3100
# data_dir: ./data
# oref_api_url: https://www.oref.org.il/WarningMessages/alert/alerts.json

# Redis key namespace for multi-instance deployments.
# When running two instances on the same Redis, set a unique prefix per instance
# so their keys and BullMQ queues don't collide.
# Config file naming convention: config.<lang>_<area-slug>.yaml
#   e.g. config.ru_tlv-south.yaml, config.he_tlv-south.yaml, config.en_petach-tikva.yaml
# Example (instance 1): redis_prefix: ru_tlv-south  → keys: ru_tlv-south:session:active
# Example (instance 2): redis_prefix: he_tlv-south  → keys: he_tlv-south:session:active
# Env var alternative:  REDIS_PREFIX=ru_tlv-south
# Omit (or leave empty) for single-instance deployments — backward-compatible.
# redis_prefix: ""

# ── Admin ─────────────────────────────────────────
# Telegram user IDs that can use /grant, /revoke, /users commands.
# admin_chat_ids: [123456789]

# ── AI Enrichment (optional) ─────────────────────
# Enriches bot messages with data scraped from Telegram news channels via
# GramJS MTProto + LangGraph. Edits the sent message in-place.
# Channels are hardcoded in src/agent/gramjs-monitor.ts
#
# ai:
#   enabled: false
#
#   # OpenRouter API key — get at openrouter.ai/settings/keys
#   openrouter_api_key: "sk-or-v1-..."
#   openrouter_filter_model: openai/gpt-oss-120b         # channel pre-filter (free)
#   openrouter_extract_model: google/gemini-3.1-flash-lite-preview # per-post extraction (paid)
#   # Fallback: openai/gpt-oss-120b:free (if keys missing)
#
#   # Redis (also used by BullMQ queue)
#   redis_url: redis://redis:6379  # use redis://localhost:6379 outside Docker
#
#   # Residential SOCKS5 proxy for GramJS (optional)
#   # socks5_proxy: socks5://user:pass@host:1080
#
#   # Delay before running agent after alert (ms). Default 2 min.
#   enrich_delay_ms: 120000
#
#   # Collect channel posts within ±N minutes of alert_ts. Default 2.
#   window_minutes: 2
#
#   # Stop monitoring if no resolved after N minutes. Default 15.
#   timeout_minutes: 15
#
#   # Max enrichment runs per alert session (default 3).
#   max_enrich_runs: 3
#
#   # Per-phase timing configuration (ms).
#   # phase_initial_delay_ms — delay before the first enrichment run.
#   # phase_enrich_delay_ms  — interval between subsequent enrichment runs.
#   # phase_timeout_ms       — max phase duration before auto-expire.
#   #
#   # phase_initial_delay_ms:
#   #   early_warning: 120000   # 2 min — wait for launch reports
#   #   red_alert: 15000        # 15s
#   #   resolved: 90000         # 90s — wait for post-incident reports
#   # phase_enrich_delay_ms:
#   #   early_warning: 60000    # 60s
#   #   red_alert: 45000        # 45s
#   #   resolved: 150000        # 150s (2.5 min)
#   # phase_timeout_ms:
#   #   early_warning: 1800000  # 30 min
#   #   red_alert: 900000       # 15 min
#   #   resolved: 600000        # 10 min
#
#   # Burner Telegram account credentials (run `npx tsx src/agent/auth.ts` for QR login)
#   mtproto:
#     api_id: 2040       # Telegram Desktop public app_id — not secret
#     api_hash: "..."
#     session_string: "" # filled by auth.ts after first login
#   area_labels:
#     "תל אביב": "Дан центр"
#     "חיפה": "Север (Хайфа)"
#     "קריות": "Галилея (Крайот)"
#     "ירושלים": "Иерусалим"

